# URL canónica del sitio. Sin esta variable, producción cae a
# https://inferioresriverplatense.com y desarrollo a http://localhost:3000.
# Setearla solo si hace falta pisar ese default (p. ej. previews de Vercel).
NEXT_PUBLIC_SITE_URL=

# Supabase (proyecto del sitio)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role para operaciones de admin (NUNCA exponer en cliente)
SUPABASE_SERVICE_ROLE_KEY=

# Conexión directa Postgres para scripts locales (migraciones/seed)
SUPABASE_DB_URL=
